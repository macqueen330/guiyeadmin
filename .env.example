# Supabase connection (Project Settings → API in the Supabase dashboard).
# When these are absent the app automatically falls back to bundled seed data,
# so it still builds and renders before the database is connected.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER ONLY, never expose to the browser (no NEXT_PUBLIC_).
# Required to enable real admin auth + account management + RBAC enforcement.
# Without it the app runs in read-only "demo mode" with a stand-in super admin.
# Find it in Project Settings → API → service_role. Set it in Vercel as a
# server-side (non-public) environment variable.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL — used for metadata / canonical links.
NEXT_PUBLIC_SITE_URL=https://guiye-admin.com
