# Supabase connection (Project Settings → API in the Supabase dashboard).
# When these are absent the app automatically falls back to bundled seed data,
# so it still builds and renders before the database is connected.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Public site URL — used for metadata / canonical links.
NEXT_PUBLIC_SITE_URL=https://guiye-admin.com
